# ============================================
# GitStory — .gitignore
# ============================================

# ─── Environments & Secrets (CRITICAL) ──────
.env
.env.*
.venv
env/
venv/
.Sabihenv/

# ─── AI Agent / Tool Directories ────────────
.claude/
.gemini/

# ─── Databases (created at runtime) ─────────
*.db
*.sqlite3
*.sqlite

# ─── ChromaDB Vector Stores ─────────────────
chroma_db/
RAG/chroma_db/

# ─── Cloned Repositories (runtime data) ─────
repos/
backend/repos/

# ─── RAG Generated Artifacts ────────────────
RAG/project_maps/

# ─── Generated / Exported Docs ──────────────
EXPORTED_README*.md
histry.md
GitStory_SRS.pdf

# ─── Java / JDK (Situation Specific) ────────
oracleJdk-26/
*.class
*.jar
*.war
*.ear

# ─── Next.js, Node.js / JavaScript ──────────
node_modules/
.next/
npm-debug.log*
yarn-error.log*
.npm/

# ─── Python Cache & Bytecode ────────────────
__pycache__/
*.py[cod]
*$py.class
*.pyo
*.pyc
.pytest_cache/
.coverage
htmlcov/

# ─── Logs ────────────────────────────────────
*.log
logs/

# ─── Build Artifacts & Compiled Output ──────
build/
dist/
out/
bin/
obj/
*.so
*.dll
*.dylib

# ─── IDEs & Editor Files ────────────────────
.vscode/
.idea/
*.swp
*.swo
*.suo
*.sln
.settings/
.project
.classpath

# ─── OS Generated Files ─────────────────────
.DS_Store
.DS_Store?
._*
Thumbs.db
ehthumbs.db
Desktop.ini